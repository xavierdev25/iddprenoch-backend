meta {
  name: Crear Invalido
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/iglesias
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "nombre": "Iglesia Invalida",
    "distritoId": 1
  }
}

tests {
  test("falta direccion, devuelve 400", function () {
    expect(res.status).to.equal(400);
  });

  test("incluye mensaje de error de validación", function () {
    expect(res.body).to.have.property("error");
  });
}
